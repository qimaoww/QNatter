#!/bin/sh

set -u

: "${NATTER_QBITTORRENT_SH:=/usr/share/natter/natter-qbittorrent.sh}"
: "${NATTER_COMMON_SH:=/usr/share/natter/natter-common.sh}"
: "${NATTER_LOGGER_BIN:=logger}"
: "${NATTER_CURL_BIN:=curl}"
: "${NATTER_UCI_BIN:=uci}"
: "${NATTER_FIREWALL_INIT:=/etc/init.d/firewall}"

. "$NATTER_QBITTORRENT_SH"
. "$NATTER_COMMON_SH"

protocol="${1:-}"
inner_ip="${2:-}"
inner_port="${3:-}"
outer_ip="${4:-}"
outer_port="${5:-}"

env_file="${NATTER_NOTIFY_ENV:-}"
if [ -n "$env_file" ] && [ -r "$env_file" ]; then
	# shellcheck disable=SC1090
	. "$env_file"
fi

log() {
	"$NATTER_LOGGER_BIN" -t natter-notify "$*"
}

runtime_slug="$(natter_runtime_slug "${NATTER_INSTANCE:-default}")"
status_file="${NATTER_STATUS_FILE:-/var/run/natter/${runtime_slug}.json}"
natter_write_status_json "$status_file" "${NATTER_INSTANCE:-default}" "$protocol" "$inner_ip" "$inner_port" "$outer_ip" "$outer_port" "mapped"

update_auto_firewall() {
	local enabled="${NATTER_AUTO_FIREWALL:-0}"
	local section="${NATTER_FIREWALL_SECTION:-natter_${runtime_slug}}"
	local name="${NATTER_FIREWALL_NAME:-Natter ${NATTER_INSTANCE:-default}}"
	local src="${NATTER_FIREWALL_SRC:-wan}"
	local port proto

	natter_bool "$enabled" || return 0
	case "$section" in
		''|*[!A-Za-z0-9_]*)
			section="natter_${runtime_slug}"
			;;
	esac
	port="$(natter_status_port "$inner_port")"
	[ "$port" != "0" ] || {
		log "auto firewall skipped for ${NATTER_INSTANCE:-default}: invalid port $inner_port"
		return 0
	}
	case "$protocol" in
		tcp|udp) proto="$protocol" ;;
		*) proto="tcp" ;;
	esac

	if ! command -v "$NATTER_UCI_BIN" >/dev/null 2>&1; then
		log "auto firewall skipped for ${NATTER_INSTANCE:-default}: uci not found"
		return 0
	fi

	"$NATTER_UCI_BIN" -q delete "firewall.${section}" >/dev/null 2>&1 || true
	if ! "$NATTER_UCI_BIN" set "firewall.${section}=rule" ||
		! "$NATTER_UCI_BIN" set "firewall.${section}.name=${name}" ||
		! "$NATTER_UCI_BIN" set "firewall.${section}.src=${src}" ||
		! "$NATTER_UCI_BIN" set "firewall.${section}.proto=${proto}" ||
		! "$NATTER_UCI_BIN" set "firewall.${section}.dest_port=${port}" ||
		! "$NATTER_UCI_BIN" set "firewall.${section}.target=ACCEPT" ||
		! "$NATTER_UCI_BIN" commit firewall; then
		log "auto firewall update failed for ${NATTER_INSTANCE:-default}"
		return 0
	fi

	if [ -x "$NATTER_FIREWALL_INIT" ]; then
		"$NATTER_FIREWALL_INIT" reload >/dev/null 2>&1 || log "firewall reload failed for ${NATTER_INSTANCE:-default}"
	fi
}

update_cloudflare_srv() {
	local enabled="${CLOUDFLARE_SRV_ENABLED:-0}"
	local url="${CLOUDFLARE_API_URL:-}"
	local token="${CLOUDFLARE_API_TOKEN:-}"
	local port timeout json

	natter_bool "$enabled" || return 0

	port="$(natter_status_port "$outer_port")"
	if [ "$port" = "0" ]; then
		log "Cloudflare SRV skipped for ${NATTER_INSTANCE:-default}: invalid outer port $outer_port"
		return 0
	fi

	if [ -z "$url" ] || [ -z "$token" ]; then
		log "Cloudflare SRV is enabled but API URL or token is empty for ${NATTER_INSTANCE:-default}"
		return 0
	fi

	if ! command -v "$NATTER_CURL_BIN" >/dev/null 2>&1; then
		log "Cloudflare SRV skipped for ${NATTER_INSTANCE:-default}: curl not found"
		return 0
	fi

	timeout="${CLOUDFLARE_TIMEOUT:-8}"
	json='{"type":"SRV","data":{"port":'"$port"'}}'
	if ! "$NATTER_CURL_BIN" -fsS -m "$timeout" -X PATCH \
		-H "Authorization: Bearer $token" \
		-H "Accept: application/json" \
		-H "Content-Type: application/json" \
		--data "$json" \
		"$url" >/dev/null; then
		log "Cloudflare SRV update failed for ${NATTER_INSTANCE:-default}: $port"
		return 0
	fi
}

update_auto_firewall
update_cloudflare_srv

run_user_notify() {
	local script="${NATTER_USER_NOTIFY:-}"

	[ -n "$script" ] || return 0
	if [ ! -x "$script" ]; then
		log "notify script is not executable for ${NATTER_INSTANCE:-default}: $script"
		return 1
	fi

	if ! "$script" "$protocol" "$inner_ip" "$inner_port" "$outer_ip" "$outer_port"; then
		log "notify script failed for ${NATTER_INSTANCE:-default}: $script"
		return 1
	fi

	return 0
}

enabled="${QBITTORRENT_ENABLED:-0}"
if [ "$enabled" != "1" ]; then
	run_user_notify
	exit 0
fi

url="$(natter_qb_normalize_url "${QBITTORRENT_URL:-}")"
username="${QBITTORRENT_USERNAME:-}"
password="${QBITTORRENT_PASSWORD:-}"
configured_port="${QBITTORRENT_TARGET_PORT:-0}"
listen_port="$(natter_qb_select_listen_port "$inner_port" "$outer_port" "$configured_port")"
cookie="/tmp/natter-qbittorrent-${runtime_slug}.cookie"
json="$(natter_qb_preferences_json "$listen_port")"

cleanup_cookie() {
	rm -f "$cookie"
}
trap cleanup_cookie EXIT HUP INT TERM

if [ -z "$url" ] || [ -z "$username" ]; then
	log "qBittorrent is enabled but URL or username is empty for ${NATTER_INSTANCE:-default}"
	natter_write_status_json "$status_file" "${NATTER_INSTANCE:-default}" "$protocol" "$inner_ip" "$inner_port" "$outer_ip" "$outer_port" "qBittorrent URL or username is empty"
	run_user_notify
	exit 0
fi

if ! natter_qb_valid_port "$listen_port"; then
	log "qBittorrent listen_port is invalid for ${NATTER_INSTANCE:-default}: $listen_port"
	natter_write_status_json "$status_file" "${NATTER_INSTANCE:-default}" "$protocol" "$inner_ip" "$inner_port" "$outer_ip" "$outer_port" "qBittorrent listen_port is invalid"
	run_user_notify
	exit 0
fi

rm -f "$cookie"
login_response="$("$NATTER_CURL_BIN" -fsS -m "${QBITTORRENT_TIMEOUT:-8}" -c "$cookie" \
	--data-urlencode "username=$username" \
	--data-urlencode "password=$password" \
	"$url/api/v2/auth/login")"
if [ "$login_response" != "Ok." ]; then
	log "qBittorrent login failed for ${NATTER_INSTANCE:-default} at $url"
	natter_write_status_json "$status_file" "${NATTER_INSTANCE:-default}" "$protocol" "$inner_ip" "$inner_port" "$outer_ip" "$outer_port" "qBittorrent login failed"
	rm -f "$cookie"
	run_user_notify
	exit 0
fi

if ! "$NATTER_CURL_BIN" -fsS -m "${QBITTORRENT_TIMEOUT:-8}" -b "$cookie" \
	--data-urlencode "json=$json" \
	"$url/api/v2/app/setPreferences" >/dev/null; then
	log "qBittorrent listen_port update failed for ${NATTER_INSTANCE:-default}: $listen_port"
	natter_write_status_json "$status_file" "${NATTER_INSTANCE:-default}" "$protocol" "$inner_ip" "$inner_port" "$outer_ip" "$outer_port" "qBittorrent update failed"
	rm -f "$cookie"
	run_user_notify
	exit 0
fi

rm -f "$cookie"
log "qBittorrent listen_port set to $listen_port for ${NATTER_INSTANCE:-default}; ${protocol} ${inner_ip}:${inner_port} -> ${outer_ip}:${outer_port}"
natter_write_status_json "$status_file" "${NATTER_INSTANCE:-default}" "$protocol" "$inner_ip" "$inner_port" "$outer_ip" "$outer_port" "qBittorrent listen_port set to $listen_port"
run_user_notify
exit 0
