#!/bin/sh

set -u

: "${QNATTER_QBITTORRENT_SH:=/usr/share/qnatter/qnatter-qbittorrent.sh}"
: "${QNATTER_COMMON_SH:=/usr/share/qnatter/qnatter-common.sh}"
: "${QNATTER_LOGGER_BIN:=logger}"
: "${QNATTER_CURL_BIN:=curl}"
: "${QNATTER_UCI_BIN:=uci}"
: "${QNATTER_FIREWALL_INIT:=/etc/init.d/firewall}"

. "$QNATTER_QBITTORRENT_SH"
. "$QNATTER_COMMON_SH"

protocol="${1:-}"
inner_ip="${2:-}"
inner_port="${3:-}"
outer_ip="${4:-}"
outer_port="${5:-}"

env_file="${QNATTER_NOTIFY_ENV:-}"
if [ -n "$env_file" ] && [ -r "$env_file" ]; then
	# shellcheck disable=SC1090
	. "$env_file"
fi

log() {
	local message="$*"

	"$QNATTER_LOGGER_BIN" -t qnatter-notify "$message" >/dev/null 2>&1 || true
	if [ -n "${QNATTER_LOG_FILE:-}" ]; then
		mkdir -p "$(dirname "$QNATTER_LOG_FILE")" >/dev/null 2>&1 || true
		printf '%s %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$message" >> "$QNATTER_LOG_FILE" 2>/dev/null || true
	fi
}

qnatter_one_line() {
	printf '%s' "${1:-}" | tr '\r\n' '  ' | sed 's/[[:space:]][[:space:]]*/ /g; s/^ //; s/ $//' | cut -c 1-300
}

qnatter_json_port() {
	printf '%s\n' "${1:-}" | sed -n 's/.*"port"[[:space:]]*:[[:space:]]*\([0-9][0-9]*\).*/\1/p' | head -n 1
}

qnatter_json_listen_port() {
	printf '%s\n' "${1:-}" | sed -n 's/.*"listen_port"[[:space:]]*:[[:space:]]*\([0-9][0-9]*\).*/\1/p' | head -n 1
}

qnatter_json_string() {
	local key="$1"

	printf '%s\n' "${2:-}" | tr '\r\n' '  ' | awk -v key="\"$key\"" '
		{
			pos = index($0, key)
			if (pos == 0)
				next
			value = substr($0, pos + length(key))
			if (value !~ /^[[:space:]]*:[[:space:]]*"/)
				next
			sub(/^[[:space:]]*:[[:space:]]*"/, "", value)
			end = index(value, "\"")
			if (end > 0) {
				print substr(value, 1, end - 1)
				exit
			}
		}
	'
}

runtime_slug="$(qnatter_runtime_slug "${QNATTER_INSTANCE:-default}")"
status_file="${QNATTER_STATUS_FILE:-/var/run/qnatter/${runtime_slug}.json}"
qnatter_write_status_json "$status_file" "${QNATTER_INSTANCE:-default}" "$protocol" "$inner_ip" "$inner_port" "$outer_ip" "$outer_port" "mapped"

update_auto_firewall() {
	local enabled="${QNATTER_AUTO_FIREWALL:-0}"
	local section="${QNATTER_FIREWALL_SECTION:-qnatter_${runtime_slug}}"
	local name="${QNATTER_FIREWALL_NAME:-QNatter ${QNATTER_INSTANCE:-default}}"
	local src="${QNATTER_FIREWALL_SRC:-wan}"
	local dest="${QNATTER_FIREWALL_DEST:-}"
	local port proto

	qnatter_bool "$enabled" || return 0
	case "$section" in
		''|*[!A-Za-z0-9_]*)
			section="qnatter_${runtime_slug}"
			;;
	esac
	port="$(qnatter_status_port "$inner_port")"
	[ "$port" != "0" ] || {
		log "auto firewall skipped for ${QNATTER_INSTANCE:-default}: invalid port $inner_port"
		return 0
	}
	case "$protocol" in
		tcp|udp) proto="$protocol" ;;
		*) proto="tcp" ;;
	esac

	if ! command -v "$QNATTER_UCI_BIN" >/dev/null 2>&1; then
		log "auto firewall skipped for ${QNATTER_INSTANCE:-default}: uci not found"
		return 0
	fi

	"$QNATTER_UCI_BIN" -q delete "firewall.${section}" >/dev/null 2>&1 || true
	if ! "$QNATTER_UCI_BIN" set "firewall.${section}=rule" ||
		! "$QNATTER_UCI_BIN" set "firewall.${section}.name=${name}" ||
		! "$QNATTER_UCI_BIN" set "firewall.${section}.src=${src}" ||
		! "$QNATTER_UCI_BIN" set "firewall.${section}.proto=${proto}" ||
		! "$QNATTER_UCI_BIN" set "firewall.${section}.dest_port=${port}"; then
		log "auto firewall update failed for ${QNATTER_INSTANCE:-default}"
		return 0
	fi
	if [ -n "$dest" ]; then
		if ! "$QNATTER_UCI_BIN" set "firewall.${section}.dest=${dest}" ||
			! "$QNATTER_UCI_BIN" set "firewall.${section}.dest_ip=${inner_ip}"; then
			log "auto firewall update failed for ${QNATTER_INSTANCE:-default}"
			return 0
		fi
	fi
	if ! "$QNATTER_UCI_BIN" set "firewall.${section}.target=ACCEPT" ||
		! "$QNATTER_UCI_BIN" commit firewall; then
		log "auto firewall update failed for ${QNATTER_INSTANCE:-default}"
		return 0
	fi

	if [ -x "$QNATTER_FIREWALL_INIT" ]; then
		"$QNATTER_FIREWALL_INIT" reload >/dev/null 2>&1 || log "firewall reload failed for ${QNATTER_INSTANCE:-default}"
	fi
}

update_cloudflare_srv() {
	local enabled="${CLOUDFLARE_SRV_ENABLED:-0}"
	local url="${CLOUDFLARE_API_URL:-}"
	local token="${CLOUDFLARE_API_TOKEN:-}"
	local zone_id="${CLOUDFLARE_ZONE_ID:-}"
	local record_id="${CLOUDFLARE_RECORD_ID:-}"
	local base="${CLOUDFLARE_API_BASE:-https://api.cloudflare.com/client/v4}"
	local port timeout json response rc current_response current_port current_name current_target
	local patched_port patched_name patched_target

	qnatter_bool "$enabled" || return 0

	port="$(qnatter_status_port "$outer_port")"
	if [ "$port" = "0" ]; then
		log "Cloudflare SRV skipped for ${QNATTER_INSTANCE:-default}: invalid outer port $outer_port"
		return 0
	fi

	if [ -z "$url" ] && [ -n "$zone_id" ] && [ -n "$record_id" ]; then
		url="${base%/}/zones/${zone_id}/dns_records/${record_id}"
	fi

	if [ -z "$url" ] || [ -z "$token" ]; then
		log "Cloudflare SRV is enabled but API URL/record or token is empty for ${QNATTER_INSTANCE:-default}"
		return 0
	fi

	if ! command -v "$QNATTER_CURL_BIN" >/dev/null 2>&1; then
		log "Cloudflare SRV skipped for ${QNATTER_INSTANCE:-default}: curl not found"
		return 0
	fi

	timeout="${CLOUDFLARE_TIMEOUT:-8}"
	json='{"type":"SRV","data":{"port":'"$port"'}}'
	log "Cloudflare SRV update started for ${QNATTER_INSTANCE:-default}: port=$port endpoint=$url"

	current_response="$("$QNATTER_CURL_BIN" -fsS -m "$timeout" \
		-H "Authorization: Bearer $token" \
		-H "Accept: application/json" \
		"$url" 2>&1)"
	rc=$?
	if [ "$rc" -eq 0 ]; then
		current_port="$(qnatter_json_port "$current_response")"
		current_name="$(qnatter_json_string name "$current_response")"
		current_target="$(qnatter_json_string target "$current_response")"
		if [ -n "$current_port$current_name$current_target" ]; then
			log "Cloudflare SRV current record for ${QNATTER_INSTANCE:-default}: name=${current_name:-unknown} target=${current_target:-unknown} port=${current_port:-unknown}"
		fi
	else
		log "Cloudflare SRV current record read failed for ${QNATTER_INSTANCE:-default}: response=$(qnatter_one_line "$current_response")"
	fi

	response="$("$QNATTER_CURL_BIN" -fsS -m "$timeout" -X PATCH \
		-H "Authorization: Bearer $token" \
		-H "Accept: application/json" \
		-H "Content-Type: application/json" \
		--data "$json" \
		"$url" 2>&1)"
	rc=$?
	if [ "$rc" -ne 0 ]; then
		log "Cloudflare SRV update failed for ${QNATTER_INSTANCE:-default}: port=$port response=$(qnatter_one_line "$response")"
		return 0
	fi

	patched_port="$(qnatter_json_port "$response")"
	[ -n "$patched_port" ] || patched_port="$port"
	patched_name="$(qnatter_json_string name "$response")"
	patched_target="$(qnatter_json_string target "$response")"
	[ -n "$patched_name" ] || patched_name="${current_name:-}"
	[ -n "$patched_target" ] || patched_target="${current_target:-}"
	if [ -n "${current_port:-}" ]; then
		if [ "$current_port" = "$patched_port" ]; then
			log "Cloudflare SRV port unchanged for ${QNATTER_INSTANCE:-default}: $patched_port name=${patched_name:-unknown} target=${patched_target:-unknown}"
		else
			log "Cloudflare SRV port changed for ${QNATTER_INSTANCE:-default}: $current_port -> $patched_port name=${patched_name:-unknown} target=${patched_target:-unknown}"
		fi
	fi
	log "Cloudflare SRV updated for ${QNATTER_INSTANCE:-default}: port=$patched_port name=${patched_name:-unknown} target=${patched_target:-unknown}"
}

update_auto_firewall
update_cloudflare_srv

run_user_notify() {
	local script="${QNATTER_USER_NOTIFY:-}"

	[ -n "$script" ] || return 0
	if [ ! -x "$script" ]; then
		log "notify script is not executable for ${QNATTER_INSTANCE:-default}: $script"
		return 1
	fi

	if ! "$script" "$protocol" "$inner_ip" "$inner_port" "$outer_ip" "$outer_port"; then
		log "notify script failed for ${QNATTER_INSTANCE:-default}: $script"
		return 1
	fi

	return 0
}

enabled="${QBITTORRENT_ENABLED:-0}"
if [ "$enabled" != "1" ]; then
	run_user_notify
	exit 0
fi

url="$(qnatter_qb_normalize_url "${QBITTORRENT_URL:-}")"
username="${QBITTORRENT_USERNAME:-}"
password="${QBITTORRENT_PASSWORD:-}"
configured_port="${QBITTORRENT_TARGET_PORT:-0}"
listen_port="$(qnatter_qb_select_listen_port "$inner_port" "$outer_port" "$configured_port")"
if qnatter_qb_valid_port "$configured_port"; then
	listen_port_source="configured"
elif qnatter_qb_valid_port "$outer_port"; then
	listen_port_source="outer"
elif qnatter_qb_valid_port "$inner_port"; then
	listen_port_source="inner"
else
	listen_port_source="invalid"
fi
cookie="/tmp/qnatter-qbittorrent-${runtime_slug}.cookie"
json="$(qnatter_qb_preferences_json "$listen_port")"

cleanup_cookie() {
	rm -f "$cookie"
}
trap cleanup_cookie EXIT HUP INT TERM

if [ -z "$url" ] || [ -z "$username" ]; then
	log "qBittorrent is enabled but URL or username is empty for ${QNATTER_INSTANCE:-default}"
	qnatter_write_status_json "$status_file" "${QNATTER_INSTANCE:-default}" "$protocol" "$inner_ip" "$inner_port" "$outer_ip" "$outer_port" "qBittorrent URL or username is empty"
	run_user_notify
	exit 0
fi

if ! qnatter_qb_valid_port "$listen_port"; then
	log "qBittorrent listen_port is invalid for ${QNATTER_INSTANCE:-default}: listen_port=$listen_port configured=$configured_port inner=$inner_port outer=$outer_port"
	qnatter_write_status_json "$status_file" "${QNATTER_INSTANCE:-default}" "$protocol" "$inner_ip" "$inner_port" "$outer_ip" "$outer_port" "qBittorrent listen_port is invalid"
	run_user_notify
	exit 0
fi

rm -f "$cookie"
log "qBittorrent update started for ${QNATTER_INSTANCE:-default}: url=$url listen_port=$listen_port source=$listen_port_source mapping=${protocol} ${inner_ip}:${inner_port} -> ${outer_ip}:${outer_port} forward=${QBITTORRENT_FORWARD:-0} target=${QBITTORRENT_TARGET_IP:-}:${QBITTORRENT_TARGET_PORT:-0} method=${QBITTORRENT_FORWARD_METHOD:-}"
login_response="$("$QNATTER_CURL_BIN" -fsS -m "${QBITTORRENT_TIMEOUT:-8}" -c "$cookie" \
	--data-urlencode "username=$username" \
	--data-urlencode "password=$password" \
	"$url/api/v2/auth/login" 2>&1)"
login_rc=$?
if [ "$login_rc" -ne 0 ] || [ "$login_response" != "Ok." ]; then
	log "qBittorrent login failed for ${QNATTER_INSTANCE:-default} at $url: response=$(qnatter_one_line "$login_response")"
	qnatter_write_status_json "$status_file" "${QNATTER_INSTANCE:-default}" "$protocol" "$inner_ip" "$inner_port" "$outer_ip" "$outer_port" "qBittorrent login failed"
	rm -f "$cookie"
	run_user_notify
	exit 0
fi
log "qBittorrent login succeeded for ${QNATTER_INSTANCE:-default} at $url"

preferences_response="$("$QNATTER_CURL_BIN" -fsS -m "${QBITTORRENT_TIMEOUT:-8}" -b "$cookie" \
	"$url/api/v2/app/preferences" 2>&1)"
preferences_rc=$?
if [ "$preferences_rc" -eq 0 ]; then
	current_listen_port="$(qnatter_json_listen_port "$preferences_response")"
	[ -n "$current_listen_port" ] && log "qBittorrent current listen_port for ${QNATTER_INSTANCE:-default}: $current_listen_port"
else
	current_listen_port=""
	log "qBittorrent current listen_port read failed for ${QNATTER_INSTANCE:-default}: response=$(qnatter_one_line "$preferences_response")"
fi

set_response="$("$QNATTER_CURL_BIN" -fsS -m "${QBITTORRENT_TIMEOUT:-8}" -b "$cookie" \
	--data-urlencode "json=$json" \
	"$url/api/v2/app/setPreferences" 2>&1)"
set_rc=$?
if [ "$set_rc" -ne 0 ]; then
	log "qBittorrent listen_port update failed for ${QNATTER_INSTANCE:-default}: listen_port=$listen_port response=$(qnatter_one_line "$set_response")"
	qnatter_write_status_json "$status_file" "${QNATTER_INSTANCE:-default}" "$protocol" "$inner_ip" "$inner_port" "$outer_ip" "$outer_port" "qBittorrent update failed"
	rm -f "$cookie"
	run_user_notify
	exit 0
fi

rm -f "$cookie"
if [ -n "${current_listen_port:-}" ]; then
	if [ "$current_listen_port" = "$listen_port" ]; then
		log "qBittorrent listen_port unchanged for ${QNATTER_INSTANCE:-default}: $listen_port source=$listen_port_source mapping=${protocol} ${inner_ip}:${inner_port} -> ${outer_ip}:${outer_port}"
	else
		log "qBittorrent listen_port changed for ${QNATTER_INSTANCE:-default}: $current_listen_port -> $listen_port source=$listen_port_source mapping=${protocol} ${inner_ip}:${inner_port} -> ${outer_ip}:${outer_port}"
	fi
fi
log "qBittorrent listen_port set to $listen_port for ${QNATTER_INSTANCE:-default}; previous=${current_listen_port:-unknown} source=$listen_port_source mapping=${protocol} ${inner_ip}:${inner_port} -> ${outer_ip}:${outer_port}"
qnatter_write_status_json "$status_file" "${QNATTER_INSTANCE:-default}" "$protocol" "$inner_ip" "$inner_port" "$outer_ip" "$outer_port" "qBittorrent listen_port set to $listen_port"
run_user_notify
exit 0
