{
	"luci-app-natter": {
		"description": "Grant access to Natter LuCI application",
		"read": {
			"uci": [ "natter", "network" ],
			"ubus": {
				"luci.natter": [ "status", "log", "cloudflare_zones", "cloudflare_srv_records" ],
				"service": [ "list" ]
			}
		},
		"write": {
			"uci": [ "natter" ],
			"ubus": {
				"luci.natter": [ "clear_log", "rename_instance" ]
			}
		}
	}
}
