#!/bin/sh

: "${QNATTER_FUNCTIONS_SH:=/lib/functions.sh}"
: "${QNATTER_COMMON_SH:=/usr/share/qnatter/qnatter-common.sh}"
: "${QNATTER_RUN_DIR:=/var/run/qnatter}"
: "${QNATTER_PROC_DIR:=/proc}"

. "$QNATTER_FUNCTIONS_SH"
. "$QNATTER_COMMON_SH"

first=1

json_pair() {
	local key="$1"
	local value="$2"
	printf '"%s":"%s"' "$(qnatter_json_escape "$key")" "$(qnatter_json_escape "$value")"
}

json_bool_pair() {
	local key="$1"
	local value="$2"
	qnatter_bool "$value" && printf '"%s":true' "$key" || printf '"%s":false' "$key"
}

status_field() {
	local file="$1"
	local key="$2"
	[ -r "$file" ] || return 0
	awk -v key="$key" '
		function html_unicode_escape(hex) {
			hex = tolower(hex)
			if (hex == "003c")
				return "<"
			if (hex == "003e")
				return ">"
			if (hex == "0026")
				return "&"
			return ""
		}
		function emit_unescaped(value,    out, i, char, escaped) {
			out = ""
			escaped = 0
			for (i = 1; i <= length(value); i++) {
				char = substr(value, i, 1)
				if (escaped) {
					if (char == "n")
						out = out "\n"
					else if (char == "r")
						out = out "\r"
					else if (char == "t")
						out = out "\t"
					else if (char == "u") {
						replacement = html_unicode_escape(substr(value, i + 1, 4))
						if (replacement != "") {
							out = out replacement
							i += 4
						} else {
							out = out "\\u"
						}
					}
					else
						out = out char
					escaped = 0
				} else if (char == "\\") {
					escaped = 1
				} else if (char == "\"") {
					print out
					exit
				} else {
					out = out char
				}
			}
		}
		{
			prefix = "\"" key "\":\""
			start = index($0, prefix)
			if (!start)
				next
			emit_unescaped(substr($0, start + length(prefix)))
		}
	' "$file"
}

status_number_field() {
	local file="$1"
	local key="$2"
	[ -r "$file" ] || return 0
	sed -n 's/.*"'"$key"'":\([0-9][0-9]*\).*/\1/p' "$file" | head -n 1
}

instance_running() {
	local name="$1"
	local status_file="$2"
	local proc env
	for proc in "$QNATTER_PROC_DIR"/[0-9]*; do
		[ -r "$proc/environ" ] || continue
		env="$({ tr '\0' '\n' < "$proc/environ"; } 2>/dev/null || true)"
		if printf '%s\n' "$env" | grep -Fx "QNATTER_INSTANCE=$name" >/dev/null 2>&1; then
			return 0
		fi
		if [ -n "$status_file" ] && printf '%s\n' "$env" | grep -Fx "QNATTER_STATUS_FILE=$status_file" >/dev/null 2>&1; then
			return 0
		fi
	done
	return 1
}

emit_instance() {
	local section="$1"
	local enabled network bind_value protocol qb_enabled qb_forward slug file running
	local inner_ip inner_port outer_ip outer_port updated_at message

	config_get enabled "$section" enabled "0"
	config_get network "$section" network "wan"
	config_get bind_value "$section" bind_value ""
	config_get protocol "$section" protocol "tcp"
	config_get qb_enabled "$section" qbittorrent_enabled "0"
	config_get qb_forward "$section" qbittorrent_forward "0"

	slug="$(qnatter_runtime_slug "$section")"
	file="${QNATTER_RUN_DIR}/${slug}.json"
	inner_ip="$(status_field "$file" inner_ip)"
	inner_port="$(status_number_field "$file" inner_port)"
	outer_ip="$(status_field "$file" outer_ip)"
	outer_port="$(status_number_field "$file" outer_port)"
	updated_at="$(status_field "$file" updated_at)"
	message="$(status_field "$file" message)"

	running=0
	instance_running "$section" "$file" && running=1

	[ "$first" = "1" ] || printf ','
	first=0
	printf '{'
	json_pair name "$section"; printf ','
	json_bool_pair enabled "$enabled"; printf ','
	json_bool_pair running "$running"; printf ','
	json_pair network "$network"; printf ','
	json_pair bind_value "$bind_value"; printf ','
	json_pair protocol "$protocol"; printf ','
	json_bool_pair qbittorrent_enabled "$qb_enabled"; printf ','
	json_bool_pair qbittorrent_forward "$qb_forward"; printf ','
	json_pair inner_ip "$inner_ip"; printf ',"inner_port":%s,' "${inner_port:-0}"
	json_pair outer_ip "$outer_ip"; printf ',"outer_port":%s,' "${outer_port:-0}"
	json_pair updated_at "$updated_at"; printf ','
	json_pair message "$message"
	printf '}'
}

printf '{"instances":['
config_load qnatter
config_foreach emit_instance instance
printf ']}'
