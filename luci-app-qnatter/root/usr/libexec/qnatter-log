#!/bin/sh

: "${QNATTER_COMMON_SH:=/usr/share/qnatter/qnatter-common.sh}"
: "${QNATTER_LOG_DIR:=/var/log/qnatter}"

. "$QNATTER_COMMON_SH"

action="${1:-read}"
instance="${2:-default}"
lines="${3:-200}"
slug="$(qnatter_runtime_slug "$instance")"
log_file="${QNATTER_LOG_DIR}/${slug}.log"

case "$lines" in
	''|*[!0-9]*) lines=200 ;;
esac

if [ "$lines" -lt 20 ]; then
	lines=20
elif [ "$lines" -gt 1000 ]; then
	lines=1000
fi

mkdir -p "$QNATTER_LOG_DIR"

case "$action" in
	clear)
		: > "$log_file"
		printf '{"ok":true}\n'
		;;
	*)
		tail -n "$lines" "$log_file" 2>/dev/null
		;;
esac
